<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <Button
            android:id="@+id/detect_sdcard"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            android:backgroundTint="#2196F3"
            android:text="Detect SD Card"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:text="Root Folder"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:padding="4dp"
            android:text="DeutscheCource Root (contains A1 and A2 subfolders)"
            android:textColor="@android:color/holo_blue_dark"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="4dp">

            <EditText
                android:id="@+id/root_path"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:background="@android:drawable/editbox_background"
                android:hint="Path to DeutscheCource folder"
                android:padding="4dp"
                android:singleLine="true"
                android:textSize="12sp" />

            <Button
                android:id="@+id/browse_button"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:padding="8dp"
                android:text="Browse"
                android:textSize="12sp" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="8dp"
            android:background="#e0e0e0" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:text="Playback Settings"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Auto-resume playback"
                android:textSize="12sp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/auto_resume"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="8dp"
            android:background="#e0e0e0" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:text="Data Management"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/clear_data"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_margin="4dp"
            android:backgroundTint="#F44336"
            android:text="Clear All App Data"
            android:textSize="12sp" />

        <Button
            android:id="@+id/view_state"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:text="View Current State"
            android:textSize="12sp"
            android:layout_margin="4dp"
            android:backgroundTint="#2196F3" />

        <Button
            android:id="@+id/reset_state"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:text="Reset to First Run"
            android:textSize="12sp"
            android:layout_margin="4dp"
            android:backgroundTint="#FF9800" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="8dp"
            android:background="#e0e0e0" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:text="Storage Information"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/storage_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:text="Calculating..."
            android:textSize="12sp" />

        <Button
            android:id="@+id/save_paths"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#4CAF50"
            android:text="Save Settings"
            android:textSize="12sp" />

    </LinearLayout>
</ScrollView>